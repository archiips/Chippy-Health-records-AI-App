# ─────────────────────────────────────────────────────────
# Chippy Backend — Environment Variables
# Copy this file: cp .env.example .env
# Fill in values before running the server.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# Gemini (free: Google AI Studio key — aistudio.google.com/apikey)
# WARNING: AI Studio free tier may use data for model training.
# For real user health data: enable billing on Google AI API or use Vertex AI.
GOOGLE_API_KEY=your-ai-studio-key-here

# Supabase — Settings → API in your Supabase project dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here   # keeps this server-side only
SUPABASE_ANON_KEY=your-anon-public-key-here

# Qdrant Cloud (leave blank in development — Chroma is used automatically)
# Free tier: qdrant.io → Create Cluster → copy URL + API key
QDRANT_URL=
QDRANT_API_KEY=

# JWT — generate a secure secret with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-openssl-rand-hex-32-output
JWT_ALGORITHM=HS256

# Environment: "development" → local Chroma  |  "production" → Qdrant Cloud
ENV=development
